import os
from ai import ask
import re
from filesystem import write_file, delete_file

PROJECTS_DIR = os.path.expanduser("~/projects")



def apply_actions(project_path, text):

    import re
    from filesystem import write_file, delete_file

    writes = re.findall(r"WRITE (.*?)\\n<<<\\n(.*?)\\n>>>", text, re.S)
    deletes = re.findall(r"DELETE (.*)", text)

    if writes:
        print("\nFiles to write:")
        for f, _ in writes:
            print(" -", f)

    if deletes:
        print("\nFiles to delete:")
        for f in deletes:
            print(" -", f)

    for filename, content in writes:
        print("Writing", filename)
        write_file(project_path, filename.strip(), content)

    for filename in deletes:
        print("Deleting", filename)
        delete_file(project_path, filename.strip())



    import re
    from filesystem import write_file, delete_file

    writes = re.findall(r"WRITE (.*?)
<<<
(.*?)
>>>", text, re.S)
    deletes = re.findall(r"DELETE (.*)", text)

    if writes:
        print("
Files to write:")
        for f, _ in writes:
            print(" -", f)

    if deletes:
        print("
Files to delete:")
        for f in deletes:
            print(" -", f)

    for filename, content in writes:
        print("Writing", filename)
        write_file(project_path, filename.strip(), content)

    for filename in deletes:
        print("Deleting", filename)
        delete_file(project_path, filename.strip())


def choose_project():

    print("\nProjects:\n")

    projects = []

    if os.path.exists(PROJECTS_DIR):
        projects = os.listdir(PROJECTS_DIR)

    for i, p in enumerate(projects):
        print(f"{i+1}) {p}")

    print(f"{len(projects)+1}) Create new project")

    choice = input("\nSelect project: ")

    try:
        idx = int(choice) - 1

        if idx < len(projects):
            return os.path.join(PROJECTS_DIR, projects[idx])

    except:
        pass

    name = input("New project name: ")

    path = os.path.join(PROJECTS_DIR, name)

    os.makedirs(path, exist_ok=True)

    return path


def main():

    project_path = choose_project()

    print("\nNemo Code")
    print("Project:", project_path)
    print()

    history = []

    while True:

        prompt = input("code> ")

        if prompt in ("exit", "quit"):
            break

        # add project context into prompt
        full_prompt = f"""
PROJECT ROOT: {project_path}

USER REQUEST:
{prompt}

All file operations must stay inside the project root.
"""

        history.append({"role": "user", "content": full_prompt})

        answer = ask(history)

        print(answer)

        apply_actions(project_path, answer)

        print("\n" + answer + "\n")

        history.append({"role": "assistant", "content": answer})


if __name__ == "__main__":
    main()
